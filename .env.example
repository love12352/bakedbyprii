# Copy this file to ".env" and fill in your values. None are required to run locally.

# Port the server listens on
PORT=3000

# Admin dashboard key — CHANGE THIS before going live (used at /admin)
ADMIN_KEY=bakedbyprii-admin

# Delivery pricing (Didcot / OX11 only)
DELIVERY_FEE=2.50
FREE_DELIVERY_OVER=20

# Order emails — confirmation to the customer at each stage (placed, accepted,
# completed, cancelled) plus a copy of new/cancelled orders to you.
# Easiest setup is a Gmail App Password (Google account -> Security -> 2-Step
# Verification -> App passwords). Emails send from SMTP_USER as a no-reply.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=BakedbyPrii@gmail.com
SMTP_PASS=          # 16-character Gmail App Password (NOT your normal password)
SMTP_FROM=bakedbyPrii <BakedbyPrii@gmail.com>
ORDER_NOTIFY_TO=BakedbyPrii@gmail.com

# Optional contact details shown in email footers (defaults shown).
CONTACT_EMAIL=BakedbyPrii@gmail.com
CONTACT_PHONE=+44 7732 262999

# Public site origin, used to build the cancel link inside emails.
# Leave blank locally (derived from the request); set to your real URL in
# production, e.g. https://bakedbyprii.onrender.com
PUBLIC_URL=
