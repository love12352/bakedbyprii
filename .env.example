# Copy this file to ".env" and fill in your values. None are required to run locally.

# Port the server listens on
PORT=3000

# Admin dashboard key — CHANGE THIS before going live (used at /admin)
ADMIN_KEY=bakedbypri-admin

# Delivery pricing (Didcot / OX11 only)
DELIVERY_FEE=2.50
FREE_DELIVERY_OVER=20

# Optional email notifications for new orders.
# Requires: npm install nodemailer
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=orders@bakedbypri.co.uk
ORDER_NOTIFY_TO=
