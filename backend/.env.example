# ─── Database ────────────────────────────────────────────────────────────────
# Neon PostgreSQL (EU region — Ireland eu-west-1 for GDPR)
DATABASE_URL="postgresql://user:password@ep-xyz.eu-west-1.aws.neon.tech/bakedbyprii?sslmode=require"

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string-min-32-chars"
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"

# ─── Stripe (UK) ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Stripe Dashboard → Developers → Webhooks → Add endpoint
# Endpoint URL: https://your-api-domain.com/api/payments/webhook
# Events to listen for: checkout.session.completed

# ─── Cloudinary (product image uploads) ──────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# Use an App Password (Google Account → Security → App Passwords)
EMAIL_USER="hello@bakedbyprii.com"
EMAIL_PASS="your-16-char-app-password"

# ─── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL="https://bakedbyprii.com"
# Used for Stripe success/cancel redirect and CORS origin

PORT=4000
NODE_ENV=production
